          "email": "Email",
          "password": "Password",
          "env": "API environment",
          "scan_interval": "Scan interval in seconds",
          "base_url_override": "Custom API base URL (optional, e.g. local proxy; not a device IP)",
          "tank_preset": "Tank size",
          "tank_volume_liters": "Tank volume in litres (custom only)",
          "tank_empty_distance_cm": "Sensor distance when tank is empty in cm",
          "tank_full_distance_cm": "Sensor distance when tank is full in cm"
        }
      },
      "reauth_confirm": {
        "title": "Reauthenticate Boum Garden",
        "description": "Enter the password for {email}.",
        "data": {
          "password": "Password"
        }
      }
    },
    "error": {
