{
  "config": {
    "step": {
      "user": {
        "title": "Boum Garden",
        "description": "Connects Home Assistant directly to the Boum IoT REST API. Note: “local” is a local development/proxy endpoint according to the Boum CLI docs, not automatically the plant device IP.",
        "data": {
          "email": "Email",
          "password": "Password",
          "env": "API environment",
          "scan_interval": "Scan interval in seconds",
          "base_url_override": "Custom API base URL (optional, e.g. local proxy; not a device IP)"
        }
      },
      "reauth_confirm": {
        "title": "Reauthenticate Boum Garden",
        "description": "Enter the password for {email}.",
        "data": {
          "password": "Password"
        }
      }
    },
    "error": {
      "cannot_connect": "Could not connect to the Boum API.",
      "invalid_auth": "Invalid Boum credentials.",
      "unknown": "Unexpected error. Check the Home Assistant log."
    },
    "abort": {
      "already_configured": "This Boum account is already configured.",
      "reauth_successful": "Reauthentication was successful."
    }
  },
